<script>
function mountTemplateIntoShadow(hostEl, templateId) {
  const tmpl = document.getElementById(templateId);
  if (!tmpl) throw new Error("Missing template: " + templateId);

  const root = hostEl.attachShadow({ mode: "open" });
  const fragment = tmpl.content.cloneNode(true);

  // Scripts inside templates do not run automatically; we run them manually.
  const scripts = Array.from(fragment.querySelectorAll("script"));
  scripts.forEach(s => s.remove());

  root.appendChild(fragment);

  scripts.forEach((s) => {
    const runner = document.createElement("script");
    runner.textContent =
      `(function(){\n` +
      `  const root = document.currentScript.getRootNode();\n` +
      s.textContent +
      `\n})();`;
    root.appendChild(runner);
  });
}

document.querySelectorAll(".viz-host").forEach(host => {
  const templateId = host.getAttribute("data-template");
  mountTemplateIntoShadow(host, templateId);
});
</script>

